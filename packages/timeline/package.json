{
  "name": "@vitecut/timeline",
  "version": "0.0.4",
  "type": "module",
  "main": "./dist-lib/index.cjs",
  "module": "./dist-lib/index.mjs",
  "types": "./dist-lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-lib/index.d.ts",
      "import": "./dist-lib/index.mjs",
      "require": "./dist-lib/index.cjs"
    },
    "./style.css": "./dist-lib/style.css"
  },
  "files": [
    "dist-lib",
    "README.md",
    "README.zh-CN.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build --config vite.lib.config.ts && npm run build:types",
    "build:types": "tsc -p tsconfig.lib.json"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
