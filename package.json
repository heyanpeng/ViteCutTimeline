{
  "name": "vite-cut-timeline-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @vitecut/demo",
    "build": "npm run build --workspace @vitecut/timeline && npm run build --workspace @vitecut/demo",
    "build:lib": "npm run build --workspace @vitecut/timeline",
    "build:demo": "npm run build --workspace @vitecut/demo",
    "preview": "npm run preview --workspace @vitecut/demo",
    "deploy": "npm run deploy --workspace @vitecut/demo",
    "deploy:github": "npm run deploy:github --workspace @vitecut/demo"
  }
}
