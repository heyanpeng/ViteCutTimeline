{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@vitecut/timeline": ["../../packages/timeline/src/index.ts"],
      "@vitecut/timeline/*": ["../../packages/timeline/src/*"]
    },
    "strict": true
  },
  "include": ["src/**/*"]
}
